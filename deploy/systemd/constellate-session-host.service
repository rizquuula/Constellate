[Unit]
Description=Constellate session host (durable PTY owner)
After=network-online.target
Wants=network-online.target

[Service]
Type=simple
# Replace YOUR_USER with the service account, or let `constellate-agent install`
# generate a populated unit for you.
User=YOUR_USER
ExecStart=/usr/local/bin/constellate-agent session-host
Restart=on-failure
RestartSec=3

[Install]
WantedBy=multi-user.target
